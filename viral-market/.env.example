# Your Mac's IP so the app on your phone can reach the backend.
# Get it by running in terminal: ipconfig getifaddr en0
# Must match the IP Expo shows (e.g. exp://172.20.10.3:8081 → use 172.20.10.3).
# Run backend with: cd backend && python3 -m uvicorn main:app --reload --host 0.0.0.0
EXPO_PUBLIC_API_URL=http://172.20.10.3:8000
